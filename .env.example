NEXT_PUBLIC_SITE_URL=https://yourdomain.com
NEXT_PUBLIC_WEB3FORMS_KEY=your_web3forms_access_key
CMS_ADMIN_PASSWORD=change_this_password

# Required for production CMS edits on read-only/serverless hosting.
# Create a GitHub fine-grained token with Contents: Read and write for this repo.
CMS_GITHUB_TOKEN=
CMS_GITHUB_REPO=https://github.com/evolve-cpu/e47-performance
CMS_GITHUB_BRANCH=main
# CMS_GITHUB_PATH=data/cms-store.json
CMS_GITHUB_PATH=https://github.com/evolve-cpu/e47-performance/blob/main/data/cms-store.json

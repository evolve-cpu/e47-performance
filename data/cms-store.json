        "seo": {
          "rawTitle": "About E47 — Movement-First Performance Brand",
          "description": "Meet the team behind E47. Physiotherapists, performance coaches, and movement specialists united by one philosophy — physical literacy for life.",
          "keywords": [
            "about E47",
            "physiotherapy team Ahmedabad",
            "movement philosophy",
            "physical literacy India",
            "E47 performance brand",
            "sports rehab team Gujarat",

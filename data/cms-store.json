        },
        "hero": {
          "image": "https://res.cloudinary.com/diuswhkzn/image/upload/v1780316563/fitness-is-something-you-attain-and-maintain-shot-of-a-fitness-group-working-out-at-the-gym--1536x763_2_dcyott.png",
          "video": "https://res.cloudinary.com/diuswhkzn/video/upload/f_auto,q_auto:eco,w_1920/v1780315780/about_hero_section_mqeabk.mp4",
